# LLM 主力模型（必填）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# LLM 快速模型（可选，简单指令用）
# LLM_FAST_MODEL=deepseek-chat
# LLM_FAST_BASE_URL=https://api.deepseek.com/v1
# LLM_FAST_API_KEY=sk-xxx

# 地图服务 Token（可选）
CESIUM_TOKEN=your-cesium-ion-token
TIANDITU_TOKEN=your-tianditu-token

# 高德地图 API Key（POI搜索/路径规划/天气等）
# 申请地址: https://lbs.amap.com/api/webservice/create-project-and-key
AMAP_API_KEY=your-amap-api-key

# Overpass API（OSM 数据查询，国内可换镜像提升稳定性）
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# 备选镜像：https://overpass.kumi.systems/api/interpreter

# 数据库（默认 SQLite，生产可改 PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/geoagent

# CORS（Docker 部署时可添加前端域名）
# CORS_ORIGINS=http://localhost:5173,http://your-domain.com

# 服务端口
PORT=8000
