# GeoAgent 环境变量配置

# App
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (PostGIS)
DATABASE_URL=postgresql+asyncpg://geoagent:geoagent_dev@localhost:5432/geoagent
DATABASE_URL_SYNC=postgresql://geoagent:geoagent_dev@localhost:5432/geoagent

# LLM — 主力模型（必填）
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# LLM — 快速模型（可选，简单指令用，不配则用主力模型）
# LLM_FAST_MODEL=qwen-turbo
# LLM_FAST_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_FAST_API_KEY=your_qwen_api_key

# LLM — 增强模型（可选，复杂多步分析用）
# LLM_ENHANCED_MODEL=qwen-max
# LLM_ENHANCED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_ENHANCED_API_KEY=your_qwen_api_key

# LLM — 推理模型（可选，多约束决策用）
# LLM_REASONING_MODEL=deepseek-reasoner
# LLM_REASONING_BASE_URL=https://api.deepseek.com/v1
# LLM_REASONING_API_KEY=your_deepseek_api_key

# Cesium Ion Token
CESIUM_TOKEN=your_cesium_token_here

# 天地图 Token
TIANDITU_TOKEN=your_tianditu_token_here

# File Upload
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE=104857600
